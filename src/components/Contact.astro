---
const reassurances = [
  'Nessun impegno',
  'Previsioni Personalizzate',
  'Risposta entro 24 ore lavorative',
];
---

<section id="contatti" class="bg-brand-navy py-24 lg:py-32">
  <div class="mx-auto max-w-5xl px-6 lg:px-10">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-16">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-green">
          Parliamone
        </p>
        <h2
          class="mt-4 font-display text-3xl font-semibold leading-[1.15] tracking-tight text-white sm:text-4xl lg:text-[44px]"
        >
          Vediamo insieme come può <span class="text-brand-green">crescere</span> il tuo
          club.
        </h2>
        <p class="mt-5 text-lg leading-relaxed text-white/70">
          Una chiamata di 30 minuti per capire la tua situazione, mostrarti la piattaforma
          in azione e ragionare insieme su numeri e tempi.
        </p>

        <ul class="mt-8 space-y-3">
          {
            reassurances.map((item) => (
              <li class="flex items-start gap-3">
                <svg
                  class="mt-0.5 h-4 w-4 flex-shrink-0 text-brand-green"
                  viewBox="0 0 20 20"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.25"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M4 10.5l3.5 3.5 8.5-9" />
                </svg>
                <span class="text-sm leading-relaxed text-white/85">{item}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <form
        id="contact-form"
        action="https://formspree.io/f/xzdywoae"
        method="POST"
        class="space-y-5 rounded-[20px] border border-white/10 bg-white/5 p-8 lg:p-10"
        novalidate
      >
        <div>
          <label for="name" class="mb-2 block text-sm font-medium text-white">
            Nome e cognome
          </label>
          <input
            id="name"
            name="name"
            type="text"
            required
            placeholder="Mario Rossi"
            autocomplete="name"
            class="w-full rounded-lg border border-white/20 bg-white/10 px-4 py-3 text-base text-white placeholder:text-white/40 transition-colors focus:border-brand-green focus:outline-none focus:ring-2 focus:ring-brand-green/30"
          />
        </div>

        <div>
          <label for="email" class="mb-2 block text-sm font-medium text-white">
            Email
          </label>
          <input
            id="email"
            name="email"
            type="email"
            required
            placeholder="mario@nomeclub.it"
            autocomplete="email"
            class="w-full rounded-lg border border-white/20 bg-white/10 px-4 py-3 text-base text-white placeholder:text-white/40 transition-colors focus:border-brand-green focus:outline-none focus:ring-2 focus:ring-brand-green/30"
          />
        </div>

        <div>
          <label for="club" class="mb-2 block text-sm font-medium text-white">
            Club o società
          </label>
          <input
            id="club"
            name="club"
            type="text"
            required
            placeholder="Es. Pallacanestro Napoli"
            autocomplete="organization"
            class="w-full rounded-lg border border-white/20 bg-white/10 px-4 py-3 text-base text-white placeholder:text-white/40 transition-colors focus:border-brand-green focus:outline-none focus:ring-2 focus:ring-brand-green/30"
          />
        </div>

        <div>
          <label for="role" class="mb-2 block text-sm font-medium text-white">
            Ruolo
          </label>
          <select
            id="role"
            name="role"
            required
            class="w-full appearance-none rounded-lg border border-white/20 bg-white/10 bg-[image:url('data:image/svg+xml;utf8,<svg%20xmlns=%22http://www.w3.org/2000/svg%22%20viewBox=%220%200%2020%2020%22%20fill=%22none%22%20stroke=%22white%22%20stroke-opacity=%220.6%22%20stroke-width=%221.75%22%20stroke-linecap=%22round%22%20stroke-linejoin=%22round%22><path%20d=%22M5%208l5%205%205-5%22/></svg>')] bg-[position:right_1rem_center] bg-[size:1rem] bg-no-repeat px-4 py-3 pr-10 text-base text-white transition-colors focus:border-brand-green focus:outline-none focus:ring-2 focus:ring-brand-green/30"
          >
            <option value="" disabled selected>Seleziona il tuo ruolo</option>
            <option value="Direttore Generale">Direttore Generale</option>
            <option value="Direttore Commerciale">Direttore Commerciale</option>
            <option value="Marketing Manager">Marketing Manager</option>
            <option value="Responsabile Sponsor">Responsabile Sponsor</option>
            <option value="Altro">Altro</option>
          </select>
        </div>

        <div>
          <label for="message" class="mb-2 block text-sm font-medium text-white">
            Messaggio <span class="font-normal text-white/50">(opzionale)</span>
          </label>
          <textarea
            id="message"
            name="message"
            rows="4"
            placeholder="Qualche dettaglio sul tuo club o sulle tue priorità (opzionale)"
            class="w-full resize-y rounded-lg border border-white/20 bg-white/10 px-4 py-3 text-base text-white placeholder:text-white/40 transition-colors focus:border-brand-green focus:outline-none focus:ring-2 focus:ring-brand-green/30"
          ></textarea>
        </div>

        <div>
          <button
            type="submit"
            class="w-full rounded-lg bg-brand-green py-4 text-base font-semibold text-brand-navy shadow-sm transition-all hover:bg-[#00d9a4] hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-green focus-visible:ring-offset-2 focus-visible:ring-offset-brand-navy disabled:cursor-not-allowed disabled:opacity-60"
          >
            Parliamone
          </button>
          <p class="mt-4 text-center text-xs leading-relaxed text-white/50">
            Cliccando "Parliamone" confermi di aver letto la nostra privacy policy.
            Non spammiamo, non condividiamo i tuoi dati.
          </p>
        </div>

        <input
          type="text"
          name="_gotcha"
          style="display:none"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
        />
        <input
          type="hidden"
          name="_subject"
          value="Nuova richiesta Parliamone — ArenaBoostX"
        />
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;

  if (form) {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const submitBtn = form.querySelector(
        'button[type="submit"]'
      ) as HTMLButtonElement | null;
      if (!submitBtn) return;

      const originalText = submitBtn.textContent ?? 'Parliamone';
      submitBtn.disabled = true;
      submitBtn.textContent = 'Invio in corso...';

      try {
        const formData = new FormData(form);
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: { Accept: 'application/json' },
        });

        if (!response.ok) throw new Error('Errore invio');

        form.innerHTML = `
          <div role="status" class="py-12 text-center">
            <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-brand-green">
              <svg class="h-8 w-8 text-brand-navy" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 10.5l3.5 3.5 8.5-9" />
              </svg>
            </div>
            <h3 class="mt-6 font-display text-2xl font-semibold text-white">
              Richiesta ricevuta
            </h3>
            <p class="mt-3 text-base leading-relaxed text-white/70">
              Ti contatteremo entro 24 ore lavorative all'email indicata.
            </p>
          </div>
        `;
      } catch (error) {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
        alert(
          "Si è verificato un errore. Riprova o scrivici direttamente a alberto@arenaboostx.com"
        );
      }
    });
  }
</script>
