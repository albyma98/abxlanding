---
const topFans = [
  { initials: 'MR', name: 'Marco R.', points: 1240 },
  { initials: 'GL', name: 'Giulia L.', points: 1085 },
  { initials: 'AT', name: 'Andrea T.', points: 920 },
];
---

<section class="relative overflow-hidden bg-white">
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <svg
      class="absolute -right-10 top-10 h-[420px] w-[420px] text-brand-green opacity-[0.09]"
      viewBox="0 0 420 420"
    >
      <defs>
        <pattern id="hero-dots" x="0" y="0" width="22" height="22" patternUnits="userSpaceOnUse">
          <circle cx="2" cy="2" r="1.6" fill="currentColor" />
        </pattern>
        <radialGradient id="hero-dots-fade" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="white" stop-opacity="1" />
          <stop offset="100%" stop-color="white" stop-opacity="0" />
        </radialGradient>
        <mask id="hero-dots-mask">
          <rect width="420" height="420" fill="url(#hero-dots-fade)" />
        </mask>
      </defs>
      <rect width="420" height="420" fill="url(#hero-dots)" mask="url(#hero-dots-mask)" />
    </svg>

    <div
      class="absolute right-[8%] top-1/2 h-[480px] w-[480px] -translate-y-1/2 rounded-full bg-brand-green/[0.05] blur-3xl"
    >
    </div>
  </div>

  <div
    class="mx-auto flex min-h-[85vh] max-w-7xl flex-col items-center gap-14 px-6 py-20 lg:flex-row lg:gap-16 lg:px-10 lg:py-28"
  >
    <div class="w-full lg:w-3/5">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-green">
        Più tifosi attivi · Più valore generato
      </p>

      <h1
        class="mt-5 font-display text-4xl font-semibold leading-[1.08] tracking-tight text-brand-navy sm:text-5xl lg:text-6xl"
      >
        Esperienze migliori per i <span class="text-brand-green">tifosi</span>, risultati
        concreti per sponsor e club.
      </h1>

      <p class="mt-6 max-w-xl text-lg leading-relaxed text-brand-navy/75">
        ArenaBoostX è la piattaforma che trasforma ogni evento in un'esperienza connessa:
        durante la partita e oltre.
      </p>

      <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:gap-4">
        <a
          href="#contatti"
          class="inline-flex items-center justify-center rounded-lg bg-brand-green px-6 py-3.5 text-base font-semibold text-white shadow-sm transition-all hover:bg-[#00b285] hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-green focus-visible:ring-offset-2"
        >
          Parliamone
        </a>
        <a
          href="#come-funziona"
          class="inline-flex items-center justify-center rounded-lg border-2 border-brand-navy px-6 py-3.5 text-base font-semibold text-brand-navy transition-colors hover:bg-brand-navy hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-navy focus-visible:ring-offset-2"
        >
          Scopri come funziona
        </a>
      </div>

      <p class="mt-6 text-sm text-brand-navy/60">
        Setup in 2 settimane · Pensato per il mercato italiano
      </p>
    </div>

    <div class="w-full lg:w-2/5">
      <div class="relative">
        <div
          class="absolute -inset-6 rounded-[28px] bg-gradient-to-br from-brand-green/10 via-white to-brand-navy/[0.03] blur-2xl"
          aria-hidden="true"
        >
        </div>

        <div
          class="relative overflow-hidden rounded-2xl bg-white shadow-[0_24px_60px_-20px_rgba(15,30,61,0.22)] ring-1 ring-brand-navy/5"
          role="img"
          aria-label="Anteprima della dashboard ArenaBoostX con metriche di engagement, classifica tifosi e attivazione sponsor"
        >
          <div class="flex items-center justify-between border-b border-brand-navy/5 px-5 py-3.5">
            <div class="flex items-center gap-1.5">
              <span class="h-2.5 w-2.5 rounded-full bg-brand-navy/15"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-brand-navy/15"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-brand-navy/15"></span>
            </div>
            <span class="font-display text-xs font-medium text-brand-navy/60">
              Dashboard club
            </span>
            <span class="flex items-center gap-1.5">
              <span class="h-2 w-2 rounded-full bg-brand-green"></span>
              <span class="text-[10px] font-medium uppercase tracking-wider text-brand-navy/50">
                Live
              </span>
            </span>
          </div>

          <div class="space-y-4 p-5">
            <div class="rounded-xl border border-brand-navy/5 bg-brand-navy/[0.015] p-4">
              <div class="flex items-baseline justify-between">
                <p class="text-[11px] font-semibold uppercase tracking-wider text-brand-navy/55">
                  Engagement evento
                </p>
                <span class="text-xs font-semibold text-brand-green">+24%</span>
              </div>
              <p class="mt-1 font-display text-3xl font-semibold text-brand-navy">8.412</p>
              <svg
                class="mt-2 h-12 w-full"
                viewBox="0 0 200 50"
                preserveAspectRatio="none"
                aria-hidden="true"
              >
                <defs>
                  <linearGradient id="hero-spark-fill" x1="0" x2="0" y1="0" y2="1">
                    <stop offset="0%" stop-color="#00c896" stop-opacity="0.28" />
                    <stop offset="100%" stop-color="#00c896" stop-opacity="0" />
                  </linearGradient>
                </defs>
                <path
                  d="M0,40 L25,34 L50,36 L75,24 L100,28 L125,16 L150,18 L175,8 L200,12 L200,50 L0,50 Z"
                  fill="url(#hero-spark-fill)"
                />
                <path
                  d="M0,40 L25,34 L50,36 L75,24 L100,28 L125,16 L150,18 L175,8 L200,12"
                  fill="none"
                  stroke="#00c896"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </div>

            <div class="rounded-xl border border-brand-navy/5 p-4">
              <div class="mb-3 flex items-center justify-between">
                <p class="text-[11px] font-semibold uppercase tracking-wider text-brand-navy/55">
                  Top tifosi
                </p>
                <span class="text-[10px] font-medium text-brand-navy/40">questa settimana</span>
              </div>
              <ul class="space-y-2.5">
                {
                  topFans.map((fan) => (
                    <li class="flex items-center justify-between">
                      <div class="flex items-center gap-2.5">
                        <div class="flex h-8 w-8 items-center justify-center rounded-full bg-brand-navy/10 text-[11px] font-semibold text-brand-navy">
                          {fan.initials}
                        </div>
                        <span class="text-sm font-medium text-brand-navy">{fan.name}</span>
                      </div>
                      <span class="text-xs font-semibold text-brand-navy/65">
                        {fan.points.toLocaleString('it-IT')} pt
                      </span>
                    </li>
                  ))
                }
              </ul>
            </div>

            <div class="rounded-xl border border-brand-navy/5 p-4">
              <div class="mb-3 flex items-center justify-between">
                <p class="text-[11px] font-semibold uppercase tracking-wider text-brand-navy/55">
                  Attivazione sponsor
                </p>
                <span
                  class="rounded-full bg-brand-green/10 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-brand-green"
                >
                  Attiva
                </span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-sm font-medium text-brand-navy">Quiz Sponsor — 3° quarto</span>
                <span class="text-xs font-semibold text-brand-navy/70">72%</span>
              </div>
              <div class="mt-2 h-1.5 w-full overflow-hidden rounded-full bg-brand-navy/10">
                <div class="h-full w-[72%] rounded-full bg-brand-green"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
