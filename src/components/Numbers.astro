<section id="numeri" class="bg-white py-24 lg:py-32">
  <div class="mx-auto max-w-6xl px-6 lg:px-10">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-green">
        I numeri
      </p>
      <h2
        class="mt-4 font-display text-3xl font-semibold leading-[1.15] tracking-tight text-brand-navy sm:text-4xl lg:text-5xl"
      >
        Una stagione completa.
        <span class="text-brand-green">Risultati misurati</span>.
      </h2>
      <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-brand-navy/70">
        Case Study 2025/26 - 1 Società Volley Serie A3 Maschile - 1200 tifosi medi a partita - 10 Partite
      </p>
    </div>

    <div class="mt-16 grid grid-cols-2 gap-6 lg:mt-20 lg:grid-cols-4 lg:gap-8">
      <article
        class="rounded-2xl border border-brand-navy/10 bg-white p-7 transition-colors duration-200 hover:border-brand-green sm:p-8"
      >
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-brand-green">
          Tifosi profilati
        </p>
        <p
          class="mt-4 font-display text-5xl font-bold leading-none tracking-tight text-brand-navy lg:text-6xl"
          data-counter
          data-target="70"
          data-format="int"
          data-suffix="+"
        >
          170+
        </p>
        <p class="mt-2 text-xs font-medium text-brand-navy/60">per partita</p>
        <p class="mt-4 text-sm leading-relaxed text-brand-navy/70">
          'Account tifoso' creati solo nelle ultime due partite.
        </p>
      </article>

      <article
        class="rounded-2xl border border-brand-navy/10 bg-white p-7 transition-colors duration-200 hover:border-brand-green sm:p-8"
      >
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-brand-green">
          Crescita engagement
        </p>
        <p
          class="mt-4 font-display text-5xl font-bold leading-none tracking-tight text-brand-navy lg:text-6xl"
          data-counter
          data-target="128"
          data-format="int"
          data-prefix="+"
          data-suffix="%"
        >
          +128%
        </p>
        <p class="mt-2 text-xs font-medium text-brand-navy/60">nella stagione</p>
        <p class="mt-4 text-sm leading-relaxed text-brand-navy/70">
          Aumento dei voti e delle interazioni dei tifosi dalla prima all'ultima partita
          della stagione regolare.
        </p>
      </article>

      <article
        class="rounded-2xl border border-brand-navy/10 bg-white p-7 transition-colors duration-200 hover:border-brand-green sm:p-8"
      >
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-brand-green">
          Sessione media
        </p>
        <p
          class="mt-4 font-display text-5xl font-bold leading-none tracking-tight text-brand-navy lg:text-6xl"
          data-counter
          data-target="128"
          data-format="minsec"
        >
          2'08"
        </p>
        <p class="mt-2 text-xs font-medium text-brand-navy/60">per tifoso</p>
        <p class="mt-4 text-sm leading-relaxed text-brand-navy/70">
          Tempo medio passato sulla piattaforma a partita. Per riferimento: TikTok 52
          secondi.
        </p>
      </article>

      <article
        class="rounded-2xl border border-brand-navy/10 bg-white p-7 transition-colors duration-200 hover:border-brand-green sm:p-8"
      >
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-brand-green">
          Integrazione fisico-digitale
        </p>
        <p
          class="mt-4 font-display text-5xl font-bold leading-none tracking-tight text-brand-navy lg:text-6xl"
          data-counter
          data-target="250"
          data-format="int"
          data-suffix="+"
        >
          250+
        </p>
        <p class="mt-2 text-xs font-medium text-brand-navy/60">scan per evento</p>
        <p class="mt-4 text-sm leading-relaxed text-brand-navy/70">
          Scansioni QR da volantini e materiali fisici al palazzetto, integrate nella
          piattaforma.
        </p>
      </article>
    </div>

    <p class="mx-auto mt-16 max-w-2xl text-center text-xs leading-relaxed text-brand-navy/50 lg:mt-20">
      I risultati possono variare in base alla base tifosi, alla lega e alla strategia di attivazione. Previsione personalizzata inclusa nella call introduttiva.
    </p>
  </div>
</section>

<script>
  type CounterFormat = 'int' | 'minsec';

  const formatters: Record<CounterFormat, (n: number) => string> = {
    int: (n) => Math.round(n).toString(),
    minsec: (totalSeconds) => {
      const m = Math.floor(totalSeconds / 60);
      const s = Math.floor(totalSeconds % 60);
      return `${m}'${s.toString().padStart(2, '0')}"`;
    },
  };

  const renderCounter = (el: HTMLElement, value: number) => {
    const format = (el.dataset.format as CounterFormat) || 'int';
    const prefix = el.dataset.prefix ?? '';
    const suffix = el.dataset.suffix ?? '';
    el.textContent = `${prefix}${formatters[format](value)}${suffix}`;
  };

  const counters = Array.from(document.querySelectorAll<HTMLElement>('[data-counter]'));
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduceMotion && counters.length > 0) {
    counters.forEach((el) => renderCounter(el, 0));

    const animate = (el: HTMLElement) => {
      const target = Number(el.dataset.target ?? '0');
      const duration = 1400;
      const start = performance.now();

      const tick = (now: number) => {
        const progress = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        renderCounter(el, target * eased);
        if (progress < 1) {
          requestAnimationFrame(tick);
        } else {
          renderCounter(el, target);
        }
      };
      requestAnimationFrame(tick);
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !(entry.target as HTMLElement).dataset.animated) {
            (entry.target as HTMLElement).dataset.animated = 'true';
            animate(entry.target as HTMLElement);
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.35, rootMargin: '0px 0px -40px 0px' }
    );

    counters.forEach((el) => observer.observe(el));
  }
</script>
