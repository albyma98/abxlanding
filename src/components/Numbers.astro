---

<section id="numeri" class="bg-white py-24 lg:py-32">
  <div class="mx-auto max-w-6xl px-6 lg:px-10">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-green">
        I numeri
      </p>
      <h2
        class="mt-4 font-display text-3xl font-semibold leading-[1.15] tracking-tight text-brand-navy sm:text-4xl lg:text-5xl"
      >
        Una stagione completa.
        <span class="text-brand-green">Risultati misurati</span>.
      </h2>
      <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-brand-navy/70">
        Dati reali raccolti con un club di volley di Serie A3 maschile durante la stagione
        2025/26 — 10 partite, oltre 12.000 spettatori complessivi.
      </p>
    </div>

    <div class="mt-16 grid grid-cols-2 gap-6 lg:mt-20 lg:grid-cols-4 lg:gap-8">
      <article
        class="rounded-2xl border border-brand-navy/10 bg-white p-7 transition-colors duration-200 hover:border-brand-green sm:p-8"
      >
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-brand-green">
          Tifosi profilati
        </p>
        <p
          class="mt-4 font-display text-5xl font-bold leading-none tracking-tight text-brand-navy lg:text-6xl"
          data-counter
          data-target="70"
          data-format="int"
          data-suffix="+"
        >
          70+
        </p>
        <p class="mt-2 text-xs font-medium text-brand-navy/60">per partita</p>
        <p class="mt-4 text-sm leading-relaxed text-brand-navy/70">
          Account creati con consenso marketing in una singola serata di gara, dopo
          l'ottimizzazione UI.
        </p>
      </article>

      <article
        class="rounded-2xl border border-brand-navy/10 bg-white p-7 transition-colors duration-200 hover:border-brand-green sm:p-8"
      >
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-brand-green">
          Crescita engagement
        </p>
        <p
          class="mt-4 font-display text-5xl font-bold leading-none tracking-tight text-brand-navy lg:text-6xl"
          data-counter
          data-target="128"
          data-format="int"
          data-prefix="+"
          data-suffix="%"
        >
          +128%
        </p>
        <p class="mt-2 text-xs font-medium text-brand-navy/60">nella stagione</p>
        <p class="mt-4 text-sm leading-relaxed text-brand-navy/70">
          Aumento dei voti e delle interazioni dei tifosi dalla prima all'ultima partita
          della stagione regolare.
        </p>
      </article>

      <article
        class="rounded-2xl border border-brand-navy/10 bg-white p-7 transition-colors duration-200 hover:border-brand-green sm:p-8"
      >
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-brand-green">
          Sessione media
        </p>
        <p
          class="mt-4 font-display text-5xl font-bold leading-none tracking-tight text-brand-navy lg:text-6xl"
          data-counter
          data-target="128"
          data-format="minsec"
        >
          2'08"
        </p>
        <p class="mt-2 text-xs font-medium text-brand-navy/60">per tifoso</p>
        <p class="mt-4 text-sm leading-relaxed text-brand-navy/70">
          Tempo medio passato sulla piattaforma a partita. Per riferimento: TikTok 52
          secondi.
        </p>
      </article>

      <article
        class="rounded-2xl border border-brand-navy/10 bg-white p-7 transition-colors duration-200 hover:border-brand-green sm:p-8"
      >
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-brand-green">
          Integrazione fisico-digitale
        </p>
        <p
          class="mt-4 font-display text-5xl font-bold leading-none tracking-tight text-brand-navy lg:text-6xl"
          data-counter
          data-target="250"
          data-format="int"
          data-suffix="+"
        >
          250+
        </p>
        <p class="mt-2 text-xs font-medium text-brand-navy/60">scan per evento</p>
        <p class="mt-4 text-sm leading-relaxed text-brand-navy/70">
          Scansioni QR da volantini e materiali fisici al palazzetto, integrate nella
          piattaforma.
        </p>
      </article>
    </div>

    <div class="mx-auto mt-24 max-w-3xl text-center lg:mt-32">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-green">
        Stima il tuo potenziale
      </p>
      <h3
        class="mt-4 font-display text-3xl font-semibold leading-[1.2] tracking-tight text-brand-navy lg:text-4xl"
      >
        Quanto può crescere il tuo club?
      </h3>
      <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-brand-navy/70">
        Inserisci alcuni dati del tuo club e ricevi una stima indicativa basata sulle
        percentuali reali del nostro case study.
      </p>
    </div>

    <div
      class="mx-auto mt-12 max-w-4xl rounded-3xl border border-brand-navy/10 bg-brand-navy/[0.04] p-8 lg:mt-16 lg:p-12"
      role="region"
      aria-label="Calcolatore di stima per il tuo club"
    >
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-2 lg:gap-12">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.16em] text-brand-green">
            I dati del tuo club
          </p>
          <div class="mt-6 space-y-5">
            <div>
              <label
                for="calc-spettatori"
                class="block text-sm font-semibold text-brand-navy"
              >
                Spettatori medi a partita
              </label>
              <input
                id="calc-spettatori"
                name="calc-spettatori"
                type="number"
                inputmode="numeric"
                min="100"
                max="20000"
                value="1200"
                aria-describedby="hint-spettatori"
                class="mt-2 w-full rounded-lg border border-brand-navy/20 bg-white px-4 py-3 text-base text-brand-navy transition-colors placeholder:text-brand-navy/40 focus:border-brand-green focus:outline-none focus:ring-2 focus:ring-brand-green/30"
              />
              <p id="hint-spettatori" class="mt-2 text-xs text-brand-navy/60">
                Inserisci la media spettatori delle vostre gare casalinghe
              </p>
            </div>

            <div>
              <label
                for="calc-partite"
                class="block text-sm font-semibold text-brand-navy"
              >
                Numero partite casalinghe a stagione
              </label>
              <input
                id="calc-partite"
                name="calc-partite"
                type="number"
                inputmode="numeric"
                min="5"
                max="50"
                value="15"
                aria-describedby="hint-partite"
                class="mt-2 w-full rounded-lg border border-brand-navy/20 bg-white px-4 py-3 text-base text-brand-navy transition-colors placeholder:text-brand-navy/40 focus:border-brand-green focus:outline-none focus:ring-2 focus:ring-brand-green/30"
              />
              <p id="hint-partite" class="mt-2 text-xs text-brand-navy/60">
                Considera regular season e play-off
              </p>
            </div>

            <div>
              <label
                for="calc-sponsor"
                class="block text-sm font-semibold text-brand-navy"
              >
                Sponsor attivi
              </label>
              <input
                id="calc-sponsor"
                name="calc-sponsor"
                type="number"
                inputmode="numeric"
                min="1"
                max="50"
                value="5"
                aria-describedby="hint-sponsor"
                class="mt-2 w-full rounded-lg border border-brand-navy/20 bg-white px-4 py-3 text-base text-brand-navy transition-colors placeholder:text-brand-navy/40 focus:border-brand-green focus:outline-none focus:ring-2 focus:ring-brand-green/30"
              />
              <p id="hint-sponsor" class="mt-2 text-xs text-brand-navy/60">
                Numero di sponsor commerciali attualmente attivi
              </p>
            </div>
          </div>
        </div>

        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.16em] text-brand-green">
            La tua stima a fine stagione
          </p>
          <dl class="mt-6 divide-y divide-brand-navy/10" aria-live="polite">
            <div class="pb-5">
              <dt class="text-sm text-brand-navy/70">Tifosi profilati a fine stagione</dt>
              <dd
                id="calc-out-tifosi"
                class="mt-2 font-display text-3xl font-bold leading-none text-brand-navy"
              >
                846
              </dd>
            </div>

            <div class="py-5">
              <dt class="text-sm text-brand-navy/70">Engagement totale stagionale</dt>
              <dd class="mt-2 font-display text-3xl font-bold leading-none text-brand-navy">
                <span id="calc-out-engagement">2.160</span>
                <span class="ml-1 align-baseline text-base font-medium text-brand-navy/60">
                  interazioni
                </span>
              </dd>
            </div>

            <div class="py-5">
              <dt class="text-sm text-brand-navy/70">Click sponsor stimati</dt>
              <dd
                id="calc-out-click"
                class="mt-2 font-display text-3xl font-bold leading-none text-brand-navy"
              >
                450
              </dd>
            </div>

            <div class="pt-5">
              <dt class="text-sm text-brand-navy/70">Database tifosi a fine stagione</dt>
              <dd
                id="calc-out-database"
                class="mt-2 font-display text-4xl font-bold leading-none text-brand-green"
              >
                592
              </dd>
              <p class="mt-2 text-xs text-brand-navy/60">
                asset commerciale proprietario, valido oltre la stagione
              </p>
            </div>
          </dl>
        </div>
      </div>
    </div>

    <div class="mx-auto mt-8 flex max-w-2xl flex-col items-center gap-8 text-center">
      <p class="text-xs leading-relaxed text-brand-navy/50">
        Stime indicative basate su percentuali reali del nostro case study. I risultati
        effettivi variano in base a base tifosi, lega, intensità delle attivazioni e qualità
        della relazione col club.
      </p>
      <a
        href="#contatti"
        class="inline-flex items-center justify-center rounded-lg bg-brand-green px-7 py-3.5 text-base font-semibold text-brand-navy shadow-sm transition-all hover:bg-[#00d9a4] hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-green focus-visible:ring-offset-2"
      >
        Vuoi una stima personalizzata? Richiedi una demo
      </a>
    </div>
  </div>
</section>

<script>
  type CounterFormat = 'int' | 'minsec';

  const formatters: Record<CounterFormat, (n: number) => string> = {
    int: (n) => Math.round(n).toString(),
    minsec: (totalSeconds) => {
      const m = Math.floor(totalSeconds / 60);
      const s = Math.floor(totalSeconds % 60);
      return `${m}'${s.toString().padStart(2, '0')}"`;
    },
  };

  const renderCounter = (el: HTMLElement, value: number) => {
    const format = (el.dataset.format as CounterFormat) || 'int';
    const prefix = el.dataset.prefix ?? '';
    const suffix = el.dataset.suffix ?? '';
    el.textContent = `${prefix}${formatters[format](value)}${suffix}`;
  };

  const counters = Array.from(document.querySelectorAll<HTMLElement>('[data-counter]'));
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduceMotion && counters.length > 0) {
    counters.forEach((el) => renderCounter(el, 0));

    const animate = (el: HTMLElement) => {
      const target = Number(el.dataset.target ?? '0');
      const duration = 1400;
      const start = performance.now();

      const tick = (now: number) => {
        const progress = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        renderCounter(el, target * eased);
        if (progress < 1) {
          requestAnimationFrame(tick);
        } else {
          renderCounter(el, target);
        }
      };
      requestAnimationFrame(tick);
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !(entry.target as HTMLElement).dataset.animated) {
            (entry.target as HTMLElement).dataset.animated = 'true';
            animate(entry.target as HTMLElement);
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.35, rootMargin: '0px 0px -40px 0px' }
    );

    counters.forEach((el) => observer.observe(el));
  }

  const fmt = new Intl.NumberFormat('it-IT');

  const inputs = {
    spettatori: document.getElementById('calc-spettatori') as HTMLInputElement | null,
    partite: document.getElementById('calc-partite') as HTMLInputElement | null,
    sponsor: document.getElementById('calc-sponsor') as HTMLInputElement | null,
  };

  const outputs = {
    tifosi: document.getElementById('calc-out-tifosi'),
    engagement: document.getElementById('calc-out-engagement'),
    click: document.getElementById('calc-out-click'),
    database: document.getElementById('calc-out-database'),
  };

  if (
    inputs.spettatori &&
    inputs.partite &&
    inputs.sponsor &&
    outputs.tifosi &&
    outputs.engagement &&
    outputs.click &&
    outputs.database
  ) {
    const clamp = (n: number, min: number, max: number) =>
      Math.min(Math.max(n, min), max);

    const parseField = (el: HTMLInputElement, min: number, max: number): number | null => {
      const raw = el.value.trim();
      if (raw === '') return null;
      const n = Number(raw);
      if (!Number.isFinite(n) || n < 0) return null;
      return clamp(n, min, max);
    };

    const setAll = (text: string) => {
      outputs.tifosi!.textContent = text;
      outputs.engagement!.textContent = text;
      outputs.click!.textContent = text;
      outputs.database!.textContent = text;
    };

    const calculate = () => {
      const spettatori = parseField(inputs.spettatori!, 100, 20000);
      const partite = parseField(inputs.partite!, 5, 50);
      const sponsor = parseField(inputs.sponsor!, 1, 50);

      if (spettatori === null || partite === null || sponsor === null) {
        setAll('—');
        return;
      }

      const tifosi = Math.round(spettatori * 0.047 * partite);
      const engagement = Math.round(spettatori * 0.12 * partite);
      const click = Math.round(spettatori * 0.025 * partite * (sponsor / 5));
      const database = Math.round(tifosi * 0.7);

      outputs.tifosi!.textContent = fmt.format(tifosi);
      outputs.engagement!.textContent = fmt.format(engagement);
      outputs.click!.textContent = fmt.format(click);
      outputs.database!.textContent = fmt.format(database);
    };

    [inputs.spettatori, inputs.partite, inputs.sponsor].forEach((el) => {
      el.addEventListener('input', calculate);
    });

    calculate();
  }
</script>
