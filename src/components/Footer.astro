---
const platformLinks = [
  { label: 'Soluzione', href: '#soluzione' },
  { label: 'I numeri', href: '#numeri' },
  { label: 'Come funziona', href: '#come-funziona' },
  { label: 'Parliamone', href: '#contatti' },
];

const legalLinks = [
  { label: 'Privacy Policy', href: '/privacy' },
  { label: 'Cookie Policy', href: '/cookie' },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-[#0a1428] text-white">
  <div class="mx-auto max-w-6xl px-6 py-12 lg:px-10 lg:py-16">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4 lg:gap-12">
      <div class="lg:col-span-2">
        <a
          href="/"
          class="inline-flex items-center rounded-md focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-green focus-visible:ring-offset-2 focus-visible:ring-offset-[#0a1428]"
          aria-label="ArenaBoostX — vai alla home"
        >
          <img src="/logo-white.svg" alt="ArenaBoostX" class="h-11 w-auto" />
        </a>
        <p class="mt-5 max-w-sm text-sm leading-relaxed text-white/60">
          La piattaforma affianco ai club sportivi.
        </p>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-[0.18em] text-white/40">
          Piattaforma
        </h4>
        <ul class="mt-4 space-y-3">
          {
            platformLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="rounded-md text-sm text-white/70 transition-colors hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-green focus-visible:ring-offset-4 focus-visible:ring-offset-[#0a1428]"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-[0.18em] text-white/40">
          Contatti
        </h4>
        <ul class="mt-4 space-y-3">
          <li>
            <a
              href="mailto:alberto@arenaboostx.com"
              class="rounded-md text-sm text-white/70 transition-colors hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-green focus-visible:ring-offset-4 focus-visible:ring-offset-[#0a1428]"
            >
              alberto@arenaboostx.com
            </a>
          </li>
          <li>
            <a
              href="https://www.linkedin.com/in/alberto-marra-b721991a7/"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-md text-sm text-white/70 transition-colors hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-green focus-visible:ring-offset-4 focus-visible:ring-offset-[#0a1428]"
            >
              LinkedIn
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 border-t border-white/10 pt-8">
      <div
        class="flex flex-col items-center justify-between gap-4 text-xs text-white/50 sm:flex-row"
      >
        <p>© {currentYear} ArenaBoostX. Tutti i diritti riservati.</p>
        <ul class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
          {
            legalLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="rounded-md text-xs text-white/50 transition-colors hover:text-white/70 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-green focus-visible:ring-offset-4 focus-visible:ring-offset-[#0a1428]"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</footer>
