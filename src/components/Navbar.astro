---
---

<header
  id="site-navbar"
  class="sticky top-0 z-50 w-full bg-white/95 backdrop-blur-sm transition-shadow duration-200"
>
  <nav
    class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 lg:px-10"
    aria-label="Navigazione principale"
  >
    <a
      href="/"
      class="flex items-center rounded-md focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-green focus-visible:ring-offset-2"
      aria-label="ArenaBoostX — vai alla home"
    >
      <img src="/logo.svg" alt="ArenaBoostX" class="h-7 w-auto md:h-9" />
    </a>

    <div class="hidden items-center gap-10 md:flex">
      <ul class="flex items-center gap-8">
        <li>
          <a
            href="#soluzione"
            class="rounded-md text-sm font-medium text-brand-navy/80 transition-colors hover:text-brand-navy focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-green focus-visible:ring-offset-4"
          >
            Soluzione
          </a>
        </li>
        <li>
          <a
            href="#come-funziona"
            class="rounded-md text-sm font-medium text-brand-navy/80 transition-colors hover:text-brand-navy focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-green focus-visible:ring-offset-4"
          >
            Come funziona
          </a>
        </li>
        <li>
          <a
            href="#contatti"
            class="rounded-md text-sm font-medium text-brand-navy/80 transition-colors hover:text-brand-navy focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-green focus-visible:ring-offset-4"
          >
            Contatti
          </a>
        </li>
      </ul>
      <a
        href="#contatti"
        class="inline-flex items-center justify-center rounded-lg bg-brand-green px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-all hover:bg-[#00b285] hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-green focus-visible:ring-offset-2"
      >
        Richiedi una demo
      </a>
    </div>

    <button
      id="menu-open"
      type="button"
      class="inline-flex items-center justify-center rounded-md p-2 text-brand-navy transition-colors hover:bg-brand-navy/5 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-green md:hidden"
      aria-label="Apri menu di navigazione"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg
        class="h-6 w-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>
</header>

<div
  id="mobile-menu"
  class="fixed inset-0 z-[60] hidden flex-col bg-white md:hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Menu di navigazione"
>
  <div class="flex items-center justify-between border-b border-brand-navy/5 px-6 py-4">
    <a href="/" aria-label="ArenaBoostX — vai alla home">
      <img src="/logo.svg" alt="ArenaBoostX" class="h-7 w-auto" />
    </a>
    <button
      id="menu-close"
      type="button"
      class="inline-flex items-center justify-center rounded-md p-2 text-brand-navy transition-colors hover:bg-brand-navy/5 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-green"
      aria-label="Chiudi menu di navigazione"
    >
      <svg
        class="h-6 w-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <nav
    class="flex flex-1 flex-col items-start gap-7 px-8 pt-12"
    aria-label="Navigazione mobile"
  >
    <a
      href="#soluzione"
      data-mobile-link
      class="font-display text-3xl font-semibold text-brand-navy"
    >
      Soluzione
    </a>
    <a
      href="#come-funziona"
      data-mobile-link
      class="font-display text-3xl font-semibold text-brand-navy"
    >
      Come funziona
    </a>
    <a
      href="#contatti"
      data-mobile-link
      class="font-display text-3xl font-semibold text-brand-navy"
    >
      Contatti
    </a>

    <a
      href="#contatti"
      data-mobile-link
      class="mt-6 inline-flex w-full items-center justify-center rounded-lg bg-brand-green px-6 py-4 text-base font-semibold text-white shadow-sm transition-colors hover:bg-[#00b285]"
    >
      Richiedi una demo
    </a>
  </nav>
</div>

<script>
  const navbar = document.getElementById('site-navbar');
  const updateShadow = () => {
    if (!navbar) return;
    navbar.classList.toggle('shadow-[0_1px_3px_rgba(15,30,61,0.06)]', window.scrollY > 8);
    navbar.classList.toggle('border-b', window.scrollY > 8);
    navbar.classList.toggle('border-brand-navy/5', window.scrollY > 8);
  };
  updateShadow();
  window.addEventListener('scroll', updateShadow, { passive: true });

  const openBtn = document.getElementById('menu-open');
  const closeBtn = document.getElementById('menu-close');
  const menu = document.getElementById('mobile-menu');
  const mobileLinks = document.querySelectorAll<HTMLAnchorElement>('[data-mobile-link]');

  const openMenu = () => {
    menu?.classList.remove('hidden');
    menu?.classList.add('flex');
    openBtn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  };

  const closeMenu = () => {
    menu?.classList.add('hidden');
    menu?.classList.remove('flex');
    openBtn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  };

  openBtn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  mobileLinks.forEach((link) => link.addEventListener('click', closeMenu));
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeMenu();
  });
</script>
