---
import Layout from './Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  lastUpdated: string;
}

const { title, description, lastUpdated } = Astro.props;
const pageTitle = `${title} — ArenaBoostX`;
const canonicalUrl = new URL(Astro.url.pathname, 'https://arenaboostx.com').toString();
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: pageTitle,
  description,
  url: canonicalUrl,
  dateModified: '2026-04-27',
  inLanguage: 'it-IT',
  isPartOf: {
    '@type': 'WebSite',
    name: 'ArenaBoostX',
    url: 'https://arenaboostx.com',
  },
};
---

<Layout title={pageTitle} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <Navbar />
  <main>
    <article class="legal-content mx-auto max-w-3xl px-6 py-24 lg:py-32">
      <header class="mb-12">
        <h1>{title}</h1>
        <p class="legal-meta">Versione 1.0 · Ultimo aggiornamento: {lastUpdated}</p>
      </header>
      <slot />
    </article>
  </main>
  <Footer />
</Layout>

<style>
  :global(.legal-content h1) {
    margin-bottom: 0.5rem;
    color: var(--color-brand-navy);
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 6vw, 2.5rem);
    font-weight: 700;
    line-height: 1.1;
  }

  :global(.legal-content .legal-meta) {
    margin-bottom: 0;
    color: color-mix(in srgb, var(--color-brand-navy) 60%, transparent);
    font-style: italic;
  }

  :global(.legal-content h2) {
    margin-top: 3rem;
    margin-bottom: 1rem;
    color: var(--color-brand-navy);
    font-family: var(--font-display);
    font-size: clamp(1.625rem, 5vw, 1.75rem);
    font-weight: 600;
    line-height: 1.2;
  }

  :global(.legal-content h3) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--color-brand-navy);
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
  }

  :global(.legal-content p) {
    margin-bottom: 1rem;
    color: color-mix(in srgb, var(--color-brand-navy) 85%, transparent);
    line-height: 1.7;
  }

  :global(.legal-content ul) {
    margin-bottom: 1rem;
    margin-left: 1.5rem;
    list-style-type: disc;
  }

  :global(.legal-content li) {
    margin-bottom: 0.5rem;
    color: color-mix(in srgb, var(--color-brand-navy) 85%, transparent);
    line-height: 1.7;
  }

  :global(.legal-content li::marker) {
    color: var(--color-brand-green);
  }

  :global(.legal-content a) {
    color: var(--color-brand-green);
    font-weight: 500;
  }

  :global(.legal-content a:hover) {
    text-decoration: underline;
  }
</style>
